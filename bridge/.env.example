# Copy to .env and adjust. The bridge reads these from the environment.

# Path to the hermes CLI (default: ~/.hermes/hermes-agent/venv/bin/hermes)
# HERMES_BIN=

# Shared-secret auth. REQUIRED on any bridge reachable from the internet -
# clients then connect with ws://host:8765/voice?token=<value>.
HERMES_BRIDGE_TOKEN=

# Which brain answers queries:
#   hermes (default) - the Hermes agent CLI (tools, agentic)
#   anthropic | openai | gemini - call that provider's API directly
#   NOTE: Direct-provider brains are single-turn only (no conversation memory;
#   use hermes brain for cross-turn conversation history and tool access)
HERMES_BRIDGE_BRAIN=hermes

# Model for the direct-provider brains (ignored for hermes)
# NOTE: Must match the selected brain's provider (e.g., Claude model id only
# works with anthropic or claude; OpenAI model id only works with openai)
HERMES_BRIDGE_MODEL=claude-opus-4-8

# Override the provider base URL (OpenAI-compatible proxies / Ollama)
# HERMES_BRIDGE_BASE_URL=

# Provider API keys (only the selected brain's key is needed)
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# Set to 1 to stream server-side TTS (edge-tts/say) for clients that
# cannot speak locally. Default off: the app speaks on-device.
HERMES_BRIDGE_TTS=
